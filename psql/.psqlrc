-- Encoding
\encoding unicode

-- Prompt
\set PROMPT1 '%n@%M:%>%x %/# '
\set PROMPT2 ''

-- Output and display
\pset null '[NULL]'
\pset linestyle unicode
\pset border 2
\x auto
\timing on
\setenv PAGER 'less -S'

-- Interactive safety
\set ON_ERROR_ROLLBACK interactive

-- History
\set HISTFILE ~/.psql_history_ :DBNAME
\set HISTCONTROL ignoredups
